ADDR=:8080
DATABASE_URL=postgres://slopyard:slopyard@localhost:5432/slopyard?sslmode=disable
# Used by `just db-setup` to create the app role/database.
# Set this to a local Postgres superuser or a role with CREATEROLE + CREATEDB.
SETUP_DATABASE_URL=postgres://your-local-postgres-user@localhost:5432/postgres?sslmode=disable
REDIS_URL=redis://localhost:6379/0
# Optional overrides used only by `just run` for the app container.
# Docker Desktop usually needs host.docker.internal to reach host services.
DOCKER_DATABASE_URL=postgres://slopyard:slopyard@host.docker.internal:5432/slopyard?sslmode=disable
DOCKER_REDIS_URL=redis://host.docker.internal:6379/0
FINGERPRINT_SECRET=change-me-to-a-long-random-secret
TRUST_PROXY_HEADERS=false
GLOBAL_RATE_LIMIT=20
GLOBAL_RATE_WINDOW=1m
HOST_REPORT_WINDOW=24h
